<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #FAE7CA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bookrecommendation.BookshelfController">
    <top>
        <AnchorPane prefHeight="60.0" prefWidth="800.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="324.0" layoutY="14.0" text="My Bookshelf" textFill="#2c3e50">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>
                <Button layoutX="14.0" layoutY="17.0" mnemonicParsing="false" onAction="#handleBackToHome" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="&lt; Back to Home" />
            </children>
        </AnchorPane>
    </top>
    <center>
        <TabPane prefHeight="400.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Want to Read">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: #FAE7CA;">
                            <content >
                                <TilePane fx:id="wantToReadPane" hgap="20.0" prefColumns="4" vgap="20.0" style="-fx-background-color:#FAE7CA;">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
                <Tab text="Currently Reading">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: #FAE7CA;">
                            <content>
                                <TilePane fx:id="readingPane" hgap="20.0" prefColumns="4" vgap="20.0">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
                <Tab text="Completed">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: #FAE7CA;">
                            <content>
                                <TilePane fx:id="completedPane" hgap="20.0" prefColumns="4" vgap="20.0">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>