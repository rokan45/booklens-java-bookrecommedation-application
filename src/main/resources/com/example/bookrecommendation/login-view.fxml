<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bookrecommendation.LoginController">
    <center>
        <VBox styleClass="form-container" maxWidth="700.0" maxHeight="500.0">
            <children>
                <Label styleClass="form-title" text="User Login" />

                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label styleClass="input-label" text="Username" />
                        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field" />
                    </children>
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label styleClass="input-label" text="Password" />
                        <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="password-field" />
                    </children>
                </VBox>

                <Button onAction="#LoginButtonAction" text="Login" styleClass="button primary-button" />

                <HBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Don't have an account?" />
                        <Hyperlink onAction="#SignUpLinkAction" text="Sign Up" styleClass="hyperlink-button" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

                <Label fx:id="messageLabel" styleClass="message-label" />
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </center>
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>
</BorderPane>